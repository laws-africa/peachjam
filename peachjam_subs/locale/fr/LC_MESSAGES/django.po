#: admin.py:42
msgid "Save the product first, then configure selectable offerings."
msgstr "Enregistrez d'abord le produit, puis configurez les offres sélectionnables."

#: admin.py:50
#, python-format
msgid "Selectable offerings for '%(product)s' must belong to that product."
msgstr "Les offres sélectionnables pour '%(product)s' doivent appartenir à ce produit."

#: admin.py:89
#, python-format
msgid "Key products must have at least one selectable offering configured: %(products)s"
msgstr "Les produits clés doivent avoir au moins une offre sélectionnable configurée : %(products)s"

#: admin.py:164
msgid "Subscription activated."
msgstr "Abonnement activé."

#: admin.py:166
msgid "Subscription cannot be activated."
msgstr "L'abonnement ne peut pas être activé."

#: admin.py:176
msgid "Subscription cancelled."
msgstr "Abonnement annulé."

#: admin.py:178
msgid "Subscription cannot be cancelled."
msgstr "L'abonnement ne peut pas être annulé."

#: admin.py:257
msgid "View"
msgstr "Voir"

#: models.py:30
#, python-format
msgid "Product '%(product)s' has more than one selectable %(period)s offering."
msgstr "Le produit '%(product)s' propose plusieurs offres %(period)s sélectionnables."

#: models.py:46
#, python-format
msgid "Product '%(product)s' annual selectable price (%(annual)s) must be higher than monthly (%(monthly)s)."
msgstr "Le prix annuel sélectionnable du produit '%(product)s' (%(annual)s) doit être supérieur au prix mensuel (%(monthly)s)."

#: models.py:76
#, python-format
msgid "Selectable %(period)s pricing must increase with tier: '%(product)s' (%(price)s) is not higher than '%(prev_product)s' (%(prev_price)s)."
msgstr "La tarification sélectionnable %(period)s doit augmenter avec le niveau : '%(product)s' (%(price)s) n'est pas supérieure à '%(prev_product)s' (%(prev_price)s)."

#: models.py:118
msgid "Offerings explicitly available to users for this product (for example monthly and annual)."
msgstr "Offres explicitement disponibles pour les utilisateurs de ce produit (par exemple, abonnements mensuels et annuels)."

#: models.py:257
msgid "Annually"
msgstr "Annuellement"

#: models.py:258
msgid "Monthly"
