#: admin.py:42
msgid "Save the product first, then configure selectable offerings."
msgstr "Primeiro, guarde o produto e, em seguida, configure as ofertas selecionáveis."

#: admin.py:50
#, python-format
msgid "Selectable offerings for '%(product)s' must belong to that product."
msgstr "As ofertas selecionáveis para '%(product)s' devem pertencer a esse produto."

#: admin.py:89
#, python-format
msgid "Key products must have at least one selectable offering configured: %(products)s"
msgstr "Os produtos principais devem ter pelo menos uma oferta selecionável configurada: %(products)s"

#: admin.py:164
msgid "Subscription activated."
msgstr "Assinatura ativada."

#: admin.py:166
msgid "Subscription cannot be activated."
msgstr "A subscrição não pode ser ativada."

#: admin.py:176
msgid "Subscription cancelled."
msgstr "Subscrição cancelada."

#: admin.py:178
msgid "Subscription cannot be cancelled."
msgstr "A subscrição não pode ser cancelada."

#: admin.py:257
msgid "View"
msgstr "Ver"

#: models.py:30
#, python-format
msgid "Product '%(product)s' has more than one selectable %(period)s offering."
msgstr "O produto '%(product)s' tem mais do que uma oferta selecionável %(period)s."

#: models.py:46
#, python-format
msgid "Product '%(product)s' annual selectable price (%(annual)s) must be higher than monthly (%(monthly)s)."
msgstr "O preço anual seleccionável do produto '%(product)s' (%(annual)s) deve ser superior ao preço mensal (%(monthly)s)."

#: models.py:76
#, python-format
msgid "Selectable %(period)s pricing must increase with tier: '%(product)s' (%(price)s) is not higher than '%(prev_product)s' (%(prev_price)s)."
msgstr "O preço seleccionável %(period)s deve aumentar com o nível: '%(product)s' (%(price)s) não é superior a '%(prev_product)s' (%(prev_price)s)."

#: models.py:118
msgid "Offerings explicitly available to users for this product (for example monthly and annual)."
msgstr "Ofertas explicitamente disponíveis para os utilizadores deste produto (por exemplo, mensais e anuais)."

#: models.py:257
msgid "Annually"
msgstr "Anualmente"

#: models.py:258
msgid "Monthly"
msgstr "Mensal"

#: models.py:268
msgid "month"
msgstr "mês"

#: models.py:269
msgid "year"
msgstr "ano"

#: models.py:289 models.py:303
msgid "FREE"
msgstr "LIVRE"

#: models.py:376
msgid "Pending"
msgstr "Pendente"

#: models.py:377
msgid "Active"
msgstr "Ativo"

#: models.py:378
msgid "Closed"
msgstr "Fechado"

#: models.py:655
msgid "Default product offering"
msgstr "Oferta de produto standard"

#: models.py:660
msgid "These products are highlighted in the product listing."
msgstr "Estes produtos são destacados na lista de produtos."

#: models.py:668
msgid "Trial product offering"
msgstr "Oferta de produto de teste"

#: models.py:669
msgid "If set, this product offering is used for trials."
msgstr "Se definido, esta oferta de produto será utilizada para testes."

#: models.py:673
msgid "Trial duration (days)"
msgstr "Duração do teste (dias)"

#: models.py:674
msgid "Number of days for the trial period."
msgstr "Número de dias para o período de teste."

#: templates/admin/peachjam_subs/subscription/change_form.html:10
msgid "Activate subscription"
msgstr "Ativar assinatura"

#: templates/admin/peachjam_subs/subscription/change_form.html:17
msgid "Cancel subscription"
msgstr "Cancelar subscrição"

#: templates/peachjam_subs/_current_and_pending_subscriptions.html:11
msgid "Upcoming change"
msgstr "Mudança futura"

#: templates/peachjam_subs/_subscription_card.html:7
msgid "Trial"
msgstr "Ensaio"

#: templates/peachjam_subs/_subscription_card.html:15
msgid "Next payment due on"
msgstr "Próximo pagamento devido em"

#: templates/peachjam_subs/_subscription_card.html:22
msgid "Begins on"
msgstr "Começa em"

#: templates/peachjam_subs/_subscription_card.html:25
msgid "Ends on"
msgstr "Termina em"

#: templates/peachjam_subs/_subscription_card.html:34
msgid "Are you sure?"
msgstr "Tem certeza?"

#: templates/peachjam_subs/_subscription_card.html:35
msgid "Cancel change"
msgstr "Cancelar alteração"

#: templates/peachjam_subs/_subscription_card.html:42
msgid "Active since"
msgstr "Ativo desde"

#: templates/peachjam_subs/_subscription_required.html:12
#: templates/peachjam_subs/_subscription_required.html:20
msgid "Create a free account"
msgstr "Crie uma conta gratuita"

#: templates/peachjam_subs/_subscription_required.html:14
#: templates/peachjam_subs/_subscription_required.html:34
msgid "Unlock this feature"
msgstr "Desbloqueie esta funcionalidade"

#: templates/peachjam_subs/_subscription_required.html:17
msgid "Sign up to save documents, read summaries and access more features."
msgstr "Registe-se para guardar documentos, ler resumos e aceder a mais recursos."

#: templates/peachjam_subs/_subscription_required.html:22
msgid "Start"
msgstr "Iniciar"

#: templates/peachjam_subs/_subscription_required.html:27
msgid "Already have an account?"
msgstr "Já tem uma conta?"

#: templates/peachjam_subs/_subscription_required.html:28
msgid "Log in"
msgstr "Efetuar Login"

#: templates/peachjam_subs/_subscription_required.html:36
#, python-format
msgid "This feature is available with %(lowest_product)s."
msgstr "Esta funcionalidade está disponível com %(lowest_product)s."

#: templates/peachjam_subs/_subscription_required.html:40
msgid "Upgrade to"
msgstr "Atualize para"

#: templates/peachjam_subs/_subscription_required.html:48
msgid "This feature is not currently available."
msgstr "Esta funcionalidade não está disponível de momento."

#: templates/peachjam_subs/subscribe.html:9
msgid "Your personal research space"
msgstr "O seu espaço de pesquisa pessoal"

#: templates/peachjam_subs/subscribe.html:11
#, python-format
msgid "%(MY_LII)s is a free account that helps you personalise and organise your legal research. It’s simple to use, always free, and makes working with the law easier."
msgstr "%(MY_LII)s é uma conta gratuita que o ajuda a personalizar e organizar a sua pesquisa jurídica. É simples de utilizar, sempre gratuita e facilita o trabalho com o direito."

#: templates/peachjam_subs/subscribe.html:15
msgid "Sign up for free"
msgstr "Registe-se gratuitamente"

#: templates/peachjam_subs/subscribe.html:28
msgid "Save documents for later"
msgstr "Guardar documentos para mais tarde"

#: templates/peachjam_subs/subscribe.html:29
msgid "Keep a library of judgments and legislation you often return to."
msgstr "Mantenha uma biblioteca de julgamentos e legislação a que recorre com frequência."

#: templates/peachjam_subs/subscribe.html:37
msgid "Organise with folders"
msgstr "Organize com pastas"

#: templates/peachjam_subs/subscribe.html:38
msgid "Group related materials together in a way that makes sense to you."
msgstr "Agrupe materiais relacionados de uma forma que faça sentido para si."

#: templates/peachjam_subs/subscribe.html:46
msgid "Add private notes"
msgstr "Adicionar notas privadas"

#: templates/peachjam_subs/subscribe.html:47
msgid "Write down reminders, insights, or context on the documents you save."
msgstr "Anote lembretes, insights ou contexto nos documentos que guardar."

#: templates/peachjam_subs/subscribe.html:55
msgid "Receive updates"
msgstr "Receber atualizações"

#: templates/peachjam_subs/subscribe.html:57
msgid "Choose topics or courts you’re interested in, and we’ll let you know when something new is published."
msgstr "Escolha temas ou tribunais do seu interesse e iremos informá-lo quando algo novo for publicado."

#: templates/peachjam_subs/subscribe.html:68
msgid "Why create an acocunt?"
msgstr "Porquê criar uma conta?"

#: templates/peachjam_subs/subscribe.html:70
msgid "Save time by not having to find the same documents again."
msgstr "Poupe tempo, pois não precisa de procurar os mesmos documentos novamente."

#: templates/peachjam_subs/subscribe.html:71
msgid "Stay organised and focused on what matters to you."
msgstr "Mantenha-se organizado e focado no que é importante para si."

#: templates/peachjam_subs/subscribe.html:72
msgid "Be notified when important new materials are available."
msgstr "Seja notificado quando novos materiais importantes estiverem disponíveis."

#: templates/peachjam_subs/subscribe.html:76
msgid "Getting started is easy"
msgstr "Começar é fácil"

#: templates/peachjam_subs/subscribe.html:78
msgid "Sign up with your email address."
msgstr "Registe-se com o seu endereço de e-mail."

#: templates/peachjam_subs/subscribe.html:79
msgid "Start saving and organising your research right away."
msgstr "Comece a guardar e a organizar a sua pesquisa agora mesmo."

#: templates/peachjam_subs/subscribe.html:80
msgid "Access your personal library wherever you are, on your desktop or phone."
msgstr "Aceda à sua biblioteca pessoal onde quer que esteja, no seu desktop ou telemóvel."

#: templates/peachjam_subs/subscribe.html:86
msgid "Create your free account"
msgstr "Crie a sua conta gratuita"

#: templates/user_account/home.html:6
msgid "Subscription"
msgstr "Subscrição"

#: views.py:30
msgid "Your pending subscription change has been cancelled."
msgstr "A sua alteração de subscrição pendente foi cancelada."
