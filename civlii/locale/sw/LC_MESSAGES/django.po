#: templates/peachjam/about.html:5
msgid "CNDJ is a member of the community of African LIIs and of the Free Access to Law Movement."
msgstr "CNDJ ni mwanachama wa jumuiya ya LII za Kiafrika na Ufikiaji Huru wa Vuguvugu la Sheria."

#: templates/peachjam/about.html:11
msgid "<a href=\"https://africanlii.org/\" target=\"_blank\" rel=\"noreferrer noopener\">AfricanLII<span class=\"visually-hidden\">opens in new tab</span></a> is a part of the <a href=\"http://www.dgru.uct.ac.za/\" target=\"_blank\" rel=\"noreferrer noopener\">Democratic<span class=\"visually-hidden\">opens in new tab</span> Governance and Rights Unit</a> at the Faculty of Law, University of Cape Town (UCT), South Africa. AfricanLII helps individuals, organizations, and governments build and maintain sustainable free access to law portals, and reach the people of Africa and beyond."
msgstr "<a href=\"https://africanlii.org/\" target=\"_blank\" rel=\"noreferrer noopener\">AfricanLII<span class=\"visually-hidden\">inafunguliwa kwenye kichupo kipya</span></a> ni sehemu ya <a href=\"http://www.dgru.uct.ac.za/\" target=\"_blank\" rel=\"noreferrer noopener\">Kidemokrasia<span class=\"visually-hidden\">inafunguliwa kwenye kichupo kipya</span> Kitengo cha Utawala na Haki</a> katika Kitivo cha Sheria, Chuo Kikuu cha Cape Town (UCT), Afrika Kusini. AfricanLII huwasaidia watu binafsi, mashirika, na serikali kujenga na kudumisha ufikiaji endelevu wa bure wa milango ya sheria, na kuwafikia watu wa Afrika na kwingineko."

#: templates/peachjam/about.html:21
msgid "<a href=\"https://laws.africa/\" target=\"_blank\" rel=\"noreferrer noopener\">Laws.Africa<span class=\"visually-hidden\">opens in new tab</span></a> is a South Africa non-profit organisation that digitises African legal information for public use. Open access to digital African legal information helps communities to thrive, businesses to succeed, and judicial officers and civil servants to deliver services efficiently and effectively."
msgstr "<a href=\"https://laws.africa/\" target=\"_blank\" rel=\"noreferrer noopener\">Laws.Africa<span class=\"visually-hidden\">inafunguliwa kwenye kichupo kipya</span></a> ni shirika lisilo la faida la Afrika Kusini ambalo hubadilisha taarifa za kisheria za Kiafrika kuwa za kidijitali kwa matumizi ya umma. Ufikiaji wazi wa taarifa za kisheria za Kiafrika husaidia jamii kustawi, biashara kufanikiwa, na maafisa wa mahakama na watumishi wa umma kutoa huduma kwa ufanisi na kwa ufanisi."

